HTTP_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=coffee_loyalty
DB_SSLMODE=disable

# Optional. Leave SMTP_HOST empty to run with no real SMTP — the sender then
# just logs each would-be email via slog.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=coffee-loyalty@example.com
