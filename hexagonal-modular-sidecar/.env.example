HTTP_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=coffee_loyalty
DB_SSLMODE=disable

# Optional. Leave SMTP_HOST empty to use the noop sender (logs only).
# When running under docker-compose, SMTP is configured for the mailworker
# (the api uses the Kafka sender and never touches SMTP directly).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=coffee-loyalty@example.com

# Optional. Leave REDIS_ADDR empty to use the noop cache.
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0

# Optional. Leave KAFKA_BROKERS empty to fall back to direct SMTP from the
# API (no queue). When set, the API enqueues mail messages and the
# mailworker binary consumes them.
KAFKA_BROKERS=
KAFKA_MAIL_TOPIC=mail.outbox
